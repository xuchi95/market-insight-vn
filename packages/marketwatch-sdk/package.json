{
  "name": "@marketwatch/sdk",
  "version": "0.1.0",
  "description": "Client SDK cho MarketWatch realtime API (vàng, tiền điện tử, xăng dầu, chứng khoán VN).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/browser/marketwatch.min.global.js",
  "unpkg": "./dist/browser/marketwatch.min.global.js",
  "jsdelivr": "./dist/browser/marketwatch.min.global.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    },
    "./browser": "./dist/browser/marketwatch.min.global.js",
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run clean && tsup",
    "prepublishOnly": "npm run typecheck && npm run build",
    "version:patch": "npm version patch -m \"chore(sdk): release v%s\"",
    "version:minor": "npm version minor -m \"chore(sdk): release v%s\"",
    "version:major": "npm version major -m \"chore(sdk): release v%s\"",
    "release": "bash ../../scripts/publish-sdk.sh",
    "release:dry": "bash ../../scripts/publish-sdk.sh --dry-run"
  },
  "keywords": ["marketwatch", "gold", "crypto", "sse", "realtime", "vietnam"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.0"
  }
}