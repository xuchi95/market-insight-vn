{
  "name": "@marketwatch/sdk",
  "version": "0.1.0",
  "description": "Client SDK cho MarketWatch realtime API (vàng, tiền điện tử, xăng dầu, chứng khoán VN).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepublishOnly": "npm run typecheck && npm run build",
    "version:patch": "npm version patch -m \"chore(sdk): release v%s\"",
    "version:minor": "npm version minor -m \"chore(sdk): release v%s\"",
    "version:major": "npm version major -m \"chore(sdk): release v%s\"",
    "release": "bash ../../scripts/publish-sdk.sh",
    "release:dry": "bash ../../scripts/publish-sdk.sh --dry-run"
  },
  "keywords": ["marketwatch", "gold", "crypto", "sse", "realtime", "vietnam"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}